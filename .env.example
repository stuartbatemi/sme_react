# React environment variables for production
# Copy this file to .env and fill in your values
# In Vercel: add these under Project Settings → Environment Variables

# URL of your deployed Node.js backend (Railway URL)
VITE_API_URL=https://your-node-backend.railway.app

# NOTE: VITE_FASTAPI_URL is no longer used. As of Lonet 2.5, district/
# activity lookups go through the Node backend (/api/advisory/districts,
# /api/advisory/activities), which decides server-side whether to call the
# Regular model or Lonet 2.5 (Premium) based on the logged-in user's tier.
# This keeps the FastAPI server address out of the browser entirely and
# means Premium users automatically see Lonet 2.5's data everywhere,
# not just on the final prediction. You can safely remove
# VITE_FASTAPI_URL from your Vercel settings if it's set there.

